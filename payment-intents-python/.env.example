# Secret API key — server-only, never ship to client.
# Get one at https://vonpay.com/developers (Activate Vora Sandbox in the dashboard).
# Sandbox keys start with vp_sk_test_; live keys start with vp_sk_live_.
VON_PAY_SECRET_KEY=

# Optional. Defaults to checkout-staging.vonpay.com so a test key Just Works
# without prod-mixing. Override to https://checkout.vonpay.com when running
# against a live key.
# VON_PAY_BASE_URL=https://checkout-staging.vonpay.com
