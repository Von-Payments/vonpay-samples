# Secret API key — server-only, never ship to client.
# Get one at https://vonpay.com/developers (Activate Vora Sandbox in the dashboard).
# Sandbox keys start with vp_sk_test_; live keys start with vp_sk_live_.
VON_PAY_SECRET_KEY=vp_sk_test_your_secret_key_here

# Per-endpoint webhook signing secret (whsec_*), shown ONCE when you create the
# webhook endpoint at https://vonpay.com/developers (webhooks). This is what
# verifies the x-vonpay-signature header — it is NOT your API key. The post-3DS
# terminal state (payment_intent.succeeded / .failed) arrives on this endpoint.
VON_PAY_WEBHOOK_SECRET=whsec_your_endpoint_signing_secret

# Optional. The SDK targets production (checkout.vonpay.com) by default; a
# vp_sk_test_ key runs in sandbox mode there — no separate host needed. Set this
# only if support directs you to a different host.
# VON_PAY_BASE_URL=https://checkout.vonpay.com

# Optional. Absolute URL the issuer's 3DS challenge returns the buyer to.
# Defaults to http://localhost:PORT/3ds/return. Must be publicly reachable in
# production (and reachable by the buyer's browser).
# VON_PAY_RETURN_URL=http://localhost:3000/3ds/return

# Port for the local Express server.
PORT=3000
