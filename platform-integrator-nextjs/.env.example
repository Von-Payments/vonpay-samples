# Platform-side base URL — used to build successUrl + webhook URLs
BASE_URL=http://localhost:3000

# Per-tenant Von Payments credentials.
# In a real platform, these are stored in your DB per merchant tenant
# (encrypted at rest), looked up at request time. For this sample, we
# use 3 env-var pairs to simulate 3 onboarded merchants.
#
# Each tenant needs:
#   - vp_sk_test_*  — secret API key (server-only, used to sign requests)
#   - ss_test_*     — session signing secret (verifies the return URL)
#
# Get keys at app.vonpay.com → /dashboard/developers → Activate Vora Sandbox.
# To simulate multiple merchants, sign up with 3 different work emails
# (each gets its own sandbox merchant).

TENANT_A_VP_SK=vp_sk_test_TENANT_A_KEY
TENANT_A_SS=ss_test_TENANT_A_SECRET

TENANT_B_VP_SK=vp_sk_test_TENANT_B_KEY
TENANT_B_SS=ss_test_TENANT_B_SECRET

TENANT_C_VP_SK=vp_sk_test_TENANT_C_KEY
TENANT_C_SS=ss_test_TENANT_C_SECRET
