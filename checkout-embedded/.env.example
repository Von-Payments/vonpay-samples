# Copy to .env and fill in. .env is gitignored.

# ── Server-side (never reaches the browser) ───────────────────────────
# Secret API key. Used to create the checkout session and to charge the
# tokenized card on the tokenize-only flow.
# Get one at https://app.vonpay.com/dashboard/developers (Create sandbox).
# Sandbox keys start with vp_sk_test_; live keys start with vp_sk_live_.
VON_PAY_SECRET_KEY=vp_sk_test_REPLACE_ME

# ── Client-side (safe to ship to the browser) ─────────────────────────
# Publishable key. The browser uses it to retrieve the session and mount
# the card field via the VORA Mirror browser SDK. It can only authenticate
# VORA's public endpoints — it cannot move money on its own.
# Match the secret key's environment (test/live).
VON_PAY_PUBLISHABLE_KEY=vp_pk_test_REPLACE_ME

# Port the sample server listens on. Defaults to 4000.
PORT=4000

# Optional. Override the API base. Leave unset to use the SDK's default
# (production, checkout.vonpay.com) — a vp_sk_test_ key runs in sandbox mode
# there. Set this only if support directs you to a different host.
# VON_PAY_API_BASE=https://checkout.vonpay.com
