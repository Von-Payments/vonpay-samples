# Your merchant API key (vp_sk_test_* in sandbox, vp_sk_live_* in production).
# This IS the secret used to verify session-level webhooks (X-VonPay-Signature).
# Get one at app.vonpay.com/dashboard/developers — never commit a real value.
VON_PAY_SECRET_KEY=

# Per-subscription signing secret (whsec_*) — used to verify subscription-level
# webhooks (x-vonpay-signature: t=...,v1=...). Created at
# app.vonpay.com/dashboard/developers/webhooks. View-once on creation; if you
# lose it, rotate. To support graceful rotation, separate the current and
# previous secret with a comma:
#   WEBHOOK_SUBSCRIPTION_SECRET=whsec_NEW,whsec_OLD
# The verifier accepts a request if EITHER secret produces a matching HMAC.
WEBHOOK_SUBSCRIPTION_SECRET=

# Port for the local Express server.
PORT=3000
