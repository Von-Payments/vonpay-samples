# Your merchant API key (vp_sk_test_* in sandbox, vp_sk_live_* in production).
# Used to construct the SDK client. Get one at app.vonpay.com/dashboard/developers
# — never commit a real value.
VON_PAY_SECRET_KEY=vp_sk_test_your_secret_key_here

# Per-endpoint webhook signing secret (whsec_*), shown ONCE when you create the
# webhook endpoint at app.vonpay.com/dashboard/developers/webhooks. This is what
# verifies the x-vonpay-signature header — it is NOT your API key. If you lose
# it, rotate (rotation is an immediate cutover — there is no "show me again").
VON_PAY_WEBHOOK_SECRET=whsec_your_endpoint_signing_secret

# Port for the local Express server.
PORT=3000
