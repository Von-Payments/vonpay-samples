# Von Payments sandbox secret key. Get one in ~30 seconds:
#   1. Sign in at https://app.vonpay.com/?next=/dashboard/developers
#   2. Click "Activate Vora Sandbox"
#   3. Copy the secret key (starts with vp_sk_test_)
#
# Used by the MCP server to authenticate against the Checkout API.
# Never commit this file to git — only .env.example.
VON_PAY_SECRET_KEY=vp_sk_test_REPLACE_ME
