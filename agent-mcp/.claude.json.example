{
  "_": "Same shape works across most MCP clients. Drop into ~/.claude.json (Claude Code), claude_desktop_config.json (Claude Desktop), or ~/.cursor/mcp.json (Cursor). Continue.dev uses a slightly different shape — see README.md. Merge with your existing mcpServers object — don't overwrite.",
  "mcpServers": {
    "vonpay-checkout": {
      "command": "npx",
      "args": ["-y", "@vonpay/checkout-mcp"],
      "env": {
        "VON_PAY_SECRET_KEY": "vp_sk_test_REPLACE_ME"
      }
    }
  }
}
