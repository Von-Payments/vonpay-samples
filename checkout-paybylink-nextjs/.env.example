# Copy to .env.local and fill in your values from /dashboard/developers

# From the "Sandbox provisioned — copy these now" banner (shown only at creation)
VON_PAY_SECRET_KEY=vp_sk_test_YOUR_KEY_HERE

# Per-endpoint webhook signing secret (whsec_...), shown once when you create the webhook endpoint. NOT your API key.
VON_PAY_WEBHOOK_SECRET=whsec_your_endpoint_signing_secret
VON_PAY_SESSION_SECRET=ss_test_YOUR_SECRET_HERE

# Used to canonicalize successUrl for v2 signed-redirect binding. Set this to
# your public origin — localhost works for dev, production URL for deploy.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
